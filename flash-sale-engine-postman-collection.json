  "item": [
    {
      "name": "1. Register Admin User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Register request completed\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"postman_admin@flashsale.com\",\n  \"password\": \"password123\",\n  \"role\": \"ADMIN\",\n  \"fullName\": \"Postman Admin User\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/v1/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "v1",
            "register"
          ]
        }
      },
      "response": []
    },
